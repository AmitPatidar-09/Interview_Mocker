# ── Application ──────────────────────────────────────────────────────────────
APP_NAME=InterviewAce AI
DEBUG=false
SECRET_KEY=change-this-to-a-very-long-random-secret-key-in-production

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./interviewace.db

# ── AI Provider ───────────────────────────────────────────────────────────────
# Choose your primary AI: ollama | groq | gemini
# Default is ollama (free, local, fully open-source)
AI_PROVIDER=ollama
# Fallback if primary fails: ollama | groq | gemini | none
AI_FALLBACK_PROVIDER=gemini

# ── Ollama (local, 100% free & open-source) ──────────────────────────────────
# Install: https://ollama.com/download
# Pull model: ollama pull llama3.1:8b
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# ── Groq (cloud, open-weight models, generous free tier) ──────────────────────
# Get API key: https://console.groq.com (free)
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama3-8b-8192

# ── Gemini (optional fallback, closed-source) ─────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# ── Judge0 (via RapidAPI) ─────────────────────────────────────────────────────
JUDGE0_API_KEY=your_rapidapi_key_here
JUDGE0_BASE_URL=https://judge0-ce.p.rapidapi.com
JUDGE0_HOST=judge0-ce.p.rapidapi.com

# ── CORS ──────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]
